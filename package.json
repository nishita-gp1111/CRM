{
  "name": "salesnest-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "node scripts/vercel-build.mjs",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local:start": "bash scripts/local-db-start.sh",
    "db:local:stop": "bash scripts/local-db-stop.sh",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "6.5.0",
    "bcryptjs": "2.4.3",
    "iconv-lite": "^0.6.3",
    "next": "15.5.19",
    "papaparse": "^5.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.13.10",
    "@types/papaparse": "^5.3.16",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "prisma": "6.5.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "3.0.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
