  isCurrent          Boolean           @default(true) @map("is_current")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metricDefinition MetricDefinition @relation(fields: [metricDefinitionId], references: [id], onDelete: Cascade)

  @@unique([metricDefinitionId, version])
  @@index([organizationId, metricDefinitionId, isCurrent])
  @@map("metric_definition_versions")
}

