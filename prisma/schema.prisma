generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  SUPER_ADMIN @map("super_admin")
  ADMIN       @map("admin")
  MANAGER     @map("manager")
  USER        @map("user")
  READ_ONLY   @map("read_only")

  @@map("organization_role")
}

enum MemberStatus {
  INVITED   @map("invited")
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")

  @@map("member_status")
}

enum StageType {
  OPEN @map("open")
  WON  @map("won")
  LOST @map("lost")

  @@map("stage_type")
}

enum DealStatus {
  OPEN @map("open")
  WON  @map("won")
  LOST @map("lost")

  @@map("deal_status")
}

enum ActivityType {
  NOTE             @map("note")
  EMAIL            @map("email")
  CALL             @map("call")
  MEETING          @map("meeting")
  TASK_CREATED     @map("task_created")
  TASK_COMPLETED   @map("task_completed")
  STAGE_CHANGED    @map("stage_changed")
  PROPERTY_UPDATED @map("property_updated")
  FORM_SUBMITTED   @map("form_submitted")
  CHAT_MESSAGE     @map("chat_message")
  SYSTEM_EVENT     @map("system_event")

  @@map("activity_type")
}

enum TaskStatus {
  TODO        @map("todo")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CANCELED    @map("canceled")

  @@map("task_status")
}

enum TaskPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")

  @@map("task_priority")
}

enum TaskType {
  CALL      @map("call")
  EMAIL     @map("email")
  FOLLOW_UP @map("follow_up")
  MEETING   @map("meeting")
  OTHER     @map("other")

  @@map("task_type")
}

enum ObjectType {
  CONTACT  @map("contact")
  COMPANY  @map("company")
  DEAL     @map("deal")
  ACTIVITY @map("activity")
  TASK     @map("task")

  @@map("object_type")
}

enum CustomPropertyObjectType {
  CONTACT @map("contact")
  COMPANY @map("company")
  DEAL    @map("deal")

  @@map("custom_property_object_type")
}

enum CustomFieldType {
  TEXT         @map("text")
  TEXTAREA     @map("textarea")
  NUMBER       @map("number")
  DATE         @map("date")
  DATETIME     @map("datetime")
  SELECT       @map("select")
  MULTI_SELECT @map("multi_select")
  CHECKBOX     @map("checkbox")
  URL          @map("url")
  EMAIL        @map("email")
  PHONE        @map("phone")

  @@map("custom_field_type")
}

enum ImportStatus {
  PENDING    @map("pending")
  VALIDATING @map("validating")
  READY      @map("ready")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")

  @@map("import_status")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(320)
  name            String    @db.VarChar(120)
  passwordHash    String    @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  memberships       OrganizationMember[]
  sessions          AuthSession[]
  ownedContacts     Contact[]            @relation("ContactOwner")
  ownedCompanies    Company[]            @relation("CompanyOwner")
  ownedDeals        Deal[]               @relation("DealOwner")
  activities        Activity[]
  ownedTasks        Task[]               @relation("TaskOwner")
  createdTasks      Task[]               @relation("TaskCreator")
  uploadedImports   ImportJob[]
  createdTemplates  EmailTemplate[]
  availabilityRules AvailabilityRule[]
  meetingLinks      MeetingLink[]
  auditLogs         AuditLog[]
  savedViews        SavedView[]
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(160)
  slug      String   @unique @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  memberships       OrganizationMember[]
  teams             Team[]
  invitations       Invitation[]
  sessions          AuthSession[]
  contacts          Contact[]
  companies         Company[]
  deals             Deal[]
  activities        Activity[]
  tasks             Task[]
  pipelines         Pipeline[]
  stages            PipelineStage[]
  associations      ObjectAssociation[]
  customProperties  CustomProperty[]
  importJobs        ImportJob[]
  emailTemplates    EmailTemplate[]
  availabilityRules AvailabilityRule[]
  meetingLinks      MeetingLink[]
  meetingBookings   MeetingBooking[]
  forms             Form[]
  formSubmissions   FormSubmission[]
  conversations     Conversation[]
  auditLogs         AuditLog[]
  savedViews        SavedView[]
}

model OrganizationMember {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(USER)
  teamId         String?          @map("team_id") @db.Uuid
  status         MemberStatus     @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, role, status])
  @@map("organization_members")
}

model Team {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String           @db.VarChar(320)
  role           OrganizationRole @default(USER)
  tokenHash      String           @unique @map("token_hash") @db.VarChar(64)
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(3)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@index([expiresAt])
  @@map("invitations")
}

model AuthSession {
  id                   String   @id @default(uuid()) @db.Uuid
  tokenHash            String   @unique @map("token_hash") @db.VarChar(64)
  userId               String   @map("user_id") @db.Uuid
  activeOrganizationId String   @map("active_organization_id") @db.Uuid
  expiresAt            DateTime @map("expires_at") @db.Timestamptz(3)
  lastSeenAt           DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization Organization @relation(fields: [activeOrganizationId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([activeOrganizationId])
  @@map("auth_sessions")
}

model Contact {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  firstName      String?   @map("first_name") @db.VarChar(120)
  lastName       String?   @map("last_name") @db.VarChar(120)
  email          String?   @db.VarChar(320)
  phone          String?   @db.VarChar(40)
  mobilePhone    String?   @map("mobile_phone") @db.VarChar(40)
  jobTitle       String?   @map("job_title") @db.VarChar(120)
  lifecycleStage String?   @map("lifecycle_stage") @db.VarChar(80)
  leadStatus     String?   @map("lead_status") @db.VarChar(80)
  source         String?   @db.VarChar(120)
  memo           String?
  customFields   Json      @default("{}") @map("custom_fields") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User?            @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  formSubmissions FormSubmission[]
  meetingBookings MeetingBooking[]
  conversations   Conversation[]

  @@unique([organizationId, email])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, ownerUserId])
  @@map("contacts")
}

model Company {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  name           String    @db.VarChar(200)
  domain         String?   @db.VarChar(255)
  phone          String?   @db.VarChar(40)
  industry       String?   @db.VarChar(120)
  address        String?
  city           String?   @db.VarChar(120)
  prefecture     String?   @db.VarChar(120)
  postalCode     String?   @map("postal_code") @db.VarChar(20)
  websiteUrl     String?   @map("website_url")
  employeeCount  Int?      @map("employee_count")
  annualRevenue  Decimal?  @map("annual_revenue") @db.Decimal(18, 2)
  customFields   Json      @default("{}") @map("custom_fields") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?        @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, domain])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, ownerUserId])
  @@map("companies")
}

model Pipeline {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(160)
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@unique([organizationId, name])
  @@index([organizationId, isDefault])
  @@map("pipelines")
}

model PipelineStage {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  pipelineId     String    @map("pipeline_id") @db.Uuid
  name           String    @db.VarChar(120)
  sortOrder      Int       @map("order")
  probability    Int       @default(0)
  stageType      StageType @default(OPEN) @map("stage_type")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@unique([pipelineId, sortOrder])
  @@unique([pipelineId, name])
  @@index([organizationId])
  @@map("pipeline_stages")
}

model Deal {
  id                String     @id @default(uuid()) @db.Uuid
  organizationId    String     @map("organization_id") @db.Uuid
  ownerUserId       String?    @map("owner_user_id") @db.Uuid
  pipelineId        String     @map("pipeline_id") @db.Uuid
  stageId           String     @map("stage_id") @db.Uuid
  name              String     @db.VarChar(200)
  amount            Decimal?   @db.Decimal(18, 2)
  expectedCloseDate DateTime?  @map("expected_close_date") @db.Date
  closeDate         DateTime?  @map("close_date") @db.Date
  probability       Int        @default(0)
  status            DealStatus @default(OPEN)
  lostReason        String?    @map("lost_reason")
  source            String?    @db.VarChar(120)
  externalId        String?    @map("external_id") @db.VarChar(160)
  customFields      Json       @default("{}") @map("custom_fields") @db.JsonB
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt         DateTime?  @map("deleted_at") @db.Timestamptz(3)

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?         @relation("DealOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage        PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  @@unique([organizationId, externalId])
  @@index([organizationId, pipelineId, stageId, deletedAt])
  @@index([organizationId, ownerUserId])
  @@map("deals")
}

model ObjectAssociation {
  id               String     @id @default(uuid()) @db.Uuid
  organizationId   String     @map("organization_id") @db.Uuid
  sourceObjectType ObjectType @map("source_object_type")
  sourceObjectId   String     @map("source_object_id") @db.Uuid
  targetObjectType ObjectType @map("target_object_type")
  targetObjectId   String     @map("target_object_id") @db.Uuid
  label            String?    @db.VarChar(80)
  isPrimary        Boolean    @default(false) @map("is_primary")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sourceObjectType, sourceObjectId, targetObjectType, targetObjectId])
  @@index([organizationId, sourceObjectType, sourceObjectId])
  @@index([organizationId, targetObjectType, targetObjectId])
  @@map("object_associations")
}

model Activity {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  type           ActivityType
  title          String       @db.VarChar(200)
  body           String?
  metadata       Json         @default("{}") @db.JsonB
  occurredAt     DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@map("activities")
}

model Task {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  ownerUserId     String       @map("owner_user_id") @db.Uuid
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  title           String       @db.VarChar(200)
  description     String?
  dueDate         DateTime?    @map("due_date") @db.Timestamptz(3)
  status          TaskStatus   @default(TODO)
  priority        TaskPriority @default(MEDIUM)
  taskType        TaskType     @default(OTHER) @map("task_type")
  completedAt     DateTime?    @map("completed_at") @db.Timestamptz(3)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User         @relation("TaskOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  createdBy    User         @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId, ownerUserId, status, dueDate])
  @@map("tasks")
}

model CustomProperty {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  objectType     CustomPropertyObjectType @map("object_type")
  name           String                   @db.VarChar(80)
  label          String                   @db.VarChar(120)
  fieldType      CustomFieldType          @map("field_type")
  options        Json                     @default("[]") @db.JsonB
  isRequired     Boolean                  @default(false) @map("is_required")
  isUnique       Boolean                  @default(false) @map("is_unique")
  sortOrder      Int                      @default(0) @map("order")
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, objectType, name])
  @@index([organizationId, objectType, sortOrder])
  @@map("custom_properties")
}

model ImportJob {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  uploadedByUserId String       @map("uploaded_by_user_id") @db.Uuid
  objectType       String       @map("object_type") @db.VarChar(80)
  status           ImportStatus @default(PENDING)
  totalRows        Int          @default(0) @map("total_rows")
  successCount     Int          @default(0) @map("success_count")
  errorCount       Int          @default(0) @map("error_count")
  skippedCount     Int          @default(0) @map("skipped_count")
  mapping          Json         @default("{}") @db.JsonB
  errorReport      Json         @default("[]") @map("error_report") @db.JsonB
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@map("import_jobs")
}

model SavedView {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  userId         String                   @map("user_id") @db.Uuid
  objectType     CustomPropertyObjectType @map("object_type")
  name           String                   @db.VarChar(120)
  filters        Json                     @default("{}") @db.JsonB
  columns        Json                     @default("[]") @db.JsonB
  sort           Json                     @default("{}") @db.JsonB
  isShared       Boolean                  @default(false) @map("is_shared")
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, objectType, name])
  @@index([organizationId, objectType, isShared])
  @@map("saved_views")
}

model EmailTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String   @db.VarChar(160)
  subject         String   @db.VarChar(200)
  body            String
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, name])
  @@map("email_templates")
}

model AvailabilityRule {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  weekday        Int
  startMinutes   Int      @map("start_minutes")
  endMinutes     Int      @map("end_minutes")
  timezone       String   @default("Asia/Tokyo") @db.VarChar(80)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, weekday])
  @@map("availability_rules")
}

model MeetingLink {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String   @db.VarChar(160)
  slug            String   @unique @db.VarChar(100)
  durationMinutes Int      @default(30) @map("duration_minutes")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings     MeetingBooking[]

  @@index([organizationId, userId])
  @@map("meeting_links")
}

model MeetingBooking {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  meetingLinkId  String   @map("meeting_link_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  guestName      String   @map("guest_name") @db.VarChar(120)
  guestEmail     String   @map("guest_email") @db.VarChar(320)
  startsAt       DateTime @map("starts_at") @db.Timestamptz(3)
  endsAt         DateTime @map("ends_at") @db.Timestamptz(3)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  meetingLink  MeetingLink  @relation(fields: [meetingLinkId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([meetingLinkId, startsAt])
  @@index([organizationId, startsAt])
  @@map("meeting_bookings")
}

model Form {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  name             String   @db.VarChar(160)
  slug             String   @unique @db.VarChar(100)
  fields           Json     @default("[]") @db.JsonB
  submitButtonText String   @default("送信する") @map("submit_button_text") @db.VarChar(80)
  redirectUrl      String?  @map("redirect_url")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions  FormSubmission[]

  @@index([organizationId])
  @@map("forms")
}

model FormSubmission {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  formId         String   @map("form_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  rawPayload     Json     @map("raw_payload") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId, formId, createdAt])
  @@map("form_submissions")
}

model Conversation {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  visitorName    String?  @map("visitor_name") @db.VarChar(120)
  visitorEmail   String?  @map("visitor_email") @db.VarChar(320)
  message        String
  metadata       Json     @default("{}") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("conversations")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String   @db.VarChar(120)
  targetType     String   @map("target_type") @db.VarChar(80)
  targetId       String?  @map("target_id") @db.Uuid
  before         Json?    @db.JsonB
  after          Json?    @db.JsonB
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, targetType, targetId])
  @@map("audit_logs")
}
