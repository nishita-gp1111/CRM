generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  SUPER_ADMIN @map("super_admin")
  ADMIN       @map("admin")
  MANAGER     @map("manager")
  USER        @map("user")
  READ_ONLY   @map("read_only")

  @@map("organization_role")
}

enum MemberStatus {
  INVITED   @map("invited")
  ACTIVE    @map("active")
  SUSPENDED @map("suspended")

  @@map("member_status")
}

enum BusinessUnitStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("business_unit_status")
}

enum WorkFunction {
  IS
  FS
  CS

  @@map("work_function")
}

enum StageType {
  OPEN @map("open")
  WON  @map("won")
  LOST @map("lost")

  @@map("stage_type")
}

enum DealStatus {
  OPEN      @map("open")
  WON       @map("won")
  LOST      @map("lost")
  CANCELLED @map("cancelled")
  INVALID   @map("invalid")
  NURTURE   @map("nurture")

  @@map("deal_status")
}

enum ProductStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  ARCHIVED @map("archived")

  @@map("product_status")
}

enum PriceBookStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("price_book_status")
}

enum DealLineItemStatus {
  PROPOSED  @map("proposed")
  WON       @map("won")
  LOST      @map("lost")
  CANCELLED @map("cancelled")

  @@map("deal_line_item_status")
}

enum ForecastCategoryStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("forecast_category_status")
}

enum DecisionMakerStatus {
  DECISION_MAKER     @map("decision_maker")
  NON_DECISION_MAKER @map("non_decision_maker")
  UNKNOWN            @map("unknown")

  @@map("decision_maker_status")
}

enum QualificationResult {
  VALID        @map("valid")
  INVALID      @map("invalid")
  CONDITION_NG @map("condition_ng")
  UNDETERMINED @map("undetermined")

  @@map("qualification_result")
}

enum DealParticipantRole {
  OWNER              @map("owner")
  APPOINTMENT_SETTER @map("appointment_setter")
  CLOSER             @map("closer")
  REFERRER           @map("referrer")
  WALK_IN_OWNER      @map("walk_in_owner")
  SUPPORT            @map("support")

  @@map("deal_participant_role")
}

enum DealParticipantStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("deal_participant_status")
}

enum MeetingBookingStatus {
  SCHEDULED   @map("scheduled")
  ATTENDED    @map("attended")
  NO_SHOW     @map("no_show")
  CANCELLED   @map("cancelled")
  RESCHEDULED @map("rescheduled")
  INVALID     @map("invalid")

  @@map("meeting_booking_status")
}

enum SalesPerformanceEventType {
  CALL                         @map("call")
  CONNECTION                   @map("connection")
  OWNER_CONTACT                @map("owner_contact")
  FULL                         @map("full")
  SHORT                        @map("short")
  CONDITION_NG                 @map("condition_ng")
  APPOINTMENT_SET              @map("appointment_set")
  VALID_MEETING                @map("valid_meeting")
  INVALID_MEETING              @map("invalid_meeting")
  MEETING_ATTENDED             @map("meeting_attended")
  DEAL_WON                     @map("deal_won")
  DEAL_LOST                    @map("deal_lost")
  REVENUE_RECOGNIZED           @map("revenue_recognized")
  GROSS_PROFIT_RECOGNIZED      @map("gross_profit_recognized")
  REFERRAL_CREATED             @map("referral_created")
  REFERRAL_APPOINTMENT_SET     @map("referral_appointment_set")
  REFERRAL_MEETING_ATTENDED    @map("referral_meeting_attended")
  REFERRAL_WON                 @map("referral_won")
  FIELD_VISIT                  @map("field_visit")
  FIELD_VISIT_CONNECTION       @map("field_visit_connection")
  FIELD_VISIT_OWNER_CONNECTION @map("field_visit_owner_connection")
  FIELD_VISIT_MEETING          @map("field_visit_meeting")
  FIELD_VISIT_APPOINTMENT_SET  @map("field_visit_appointment_set")
  FIELD_VISIT_WON              @map("field_visit_won")
  FIELD_VISIT_SAME_DAY_WON     @map("field_visit_same_day_won")
  DOMAIN_ATTACHMENT            @map("domain_attachment")

  @@map("sales_performance_event_type")
}

enum SalesPerformanceEventSource {
  MANUAL   @map("manual")
  SYSTEM   @map("system")
  IMPORT   @map("import")
  BACKFILL @map("backfill")

  @@map("sales_performance_event_source")
}

enum ReferralStatus {
  NEW              @map("new")
  APPOINTMENT_SET  @map("appointment_set")
  MEETING_ATTENDED @map("meeting_attended")
  WON              @map("won")
  LOST             @map("lost")
  CANCELLED        @map("cancelled")

  @@map("referral_status")
}

enum FieldVisitStatus {
  PLANNED         @map("planned")
  VISITED         @map("visited")
  CONNECTED       @map("connected")
  OWNER_CONNECTED @map("owner_connected")
  MEETING_SET     @map("meeting_set")
  APPOINTMENT_SET @map("appointment_set")
  WON             @map("won")
  LOST            @map("lost")
  INVALID         @map("invalid")

  @@map("field_visit_status")
}

enum MetricSourceType {
  MANUAL_DAILY      @map("manual_daily")
  PERFORMANCE_EVENT @map("performance_event")
  APPOINTMENT       @map("appointment")
  DEAL              @map("deal")
  DEAL_LINE_ITEM    @map("deal_line_item")
  REFERRAL          @map("referral")
  FIELD_VISIT       @map("field_visit")
  FORMULA           @map("formula")
  DELIVERY_PROJECT  @map("delivery_project")

  @@map("metric_source_type")
}

enum MetricCategory {
  EXECUTIVE   @map("executive")
  OUTCOME     @map("outcome")
  PIPELINE    @map("pipeline")
  ACTIVITY    @map("activity")
  CONVERSION  @map("conversion")
  QUALITY     @map("quality")
  REFERRAL    @map("referral")
  FIELD_VISIT @map("field_visit")
  PRODUCT     @map("product")
  FORECAST    @map("forecast")
  ACTION_PLAN @map("action_plan")
  CS          @map("cs")

  @@map("metric_category")
}

enum MetricUnit {
  COUNT    @map("count")
  CURRENCY @map("currency")
  PERCENT  @map("percent")
  DAYS     @map("days")
  NUMBER   @map("number")

  @@map("metric_unit")
}

enum MetricAggregation {
  COUNT          @map("count")
  DISTINCT_COUNT @map("distinct_count")
  SUM            @map("sum")
  AVERAGE        @map("average")
  RATE           @map("rate")

  @@map("metric_aggregation")
}

enum MetricPeriodType {
  DAILY     @map("daily")
  WEEKLY    @map("weekly")
  MONTHLY   @map("monthly")
  QUARTERLY @map("quarterly")
  YEARLY    @map("yearly")
  CUSTOM    @map("custom")

  @@map("metric_period_type")
}

enum DailyMetricStatus {
  DRAFT     @map("draft")
  SUBMITTED @map("submitted")
  APPROVED  @map("approved")
  LOCKED    @map("locked")

  @@map("daily_metric_status")
}

enum DailyMetricSource {
  MANUAL     @map("manual")
  IMPORT     @map("import")
  BACKFILL   @map("backfill")
  ADJUSTMENT @map("adjustment")

  @@map("daily_metric_source")
}

enum ValidationSeverity {
  INFO    @map("info")
  WARNING @map("warning")
  ERROR   @map("error")

  @@map("validation_severity")
}

enum ActionPlanStatus {
  NOT_STARTED @map("not_started")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CANCELLED   @map("cancelled")

  @@map("action_plan_status")
}

enum ActionPlanPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")

  @@map("action_plan_priority")
}

enum ActivityType {
  NOTE             @map("note")
  EMAIL            @map("email")
  CALL             @map("call")
  MEETING          @map("meeting")
  TASK_CREATED     @map("task_created")
  TASK_COMPLETED   @map("task_completed")
  STAGE_CHANGED    @map("stage_changed")
  PROPERTY_UPDATED @map("property_updated")
  FORM_SUBMITTED   @map("form_submitted")
  CHAT_MESSAGE     @map("chat_message")
  SYSTEM_EVENT     @map("system_event")

  @@map("activity_type")
}

enum TaskStatus {
  TODO        @map("todo")
  IN_PROGRESS @map("in_progress")
  COMPLETED   @map("completed")
  CANCELED    @map("canceled")

  @@map("task_status")
}

enum TaskPriority {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")

  @@map("task_priority")
}

enum TaskType {
  CALL      @map("call")
  EMAIL     @map("email")
  FOLLOW_UP @map("follow_up")
  MEETING   @map("meeting")
  OTHER     @map("other")

  @@map("task_type")
}

enum ObjectType {
  CONTACT  @map("contact")
  COMPANY  @map("company")
  DEAL     @map("deal")
  ACTIVITY @map("activity")
  TASK     @map("task")

  @@map("object_type")
}

enum CustomPropertyObjectType {
  CONTACT @map("contact")
  COMPANY @map("company")
  DEAL    @map("deal")

  @@map("custom_property_object_type")
}

enum CustomFieldType {
  TEXT         @map("text")
  TEXTAREA     @map("textarea")
  NUMBER       @map("number")
  DATE         @map("date")
  DATETIME     @map("datetime")
  SELECT       @map("select")
  MULTI_SELECT @map("multi_select")
  CHECKBOX     @map("checkbox")
  URL          @map("url")
  EMAIL        @map("email")
  PHONE        @map("phone")

  @@map("custom_field_type")
}

enum ImportStatus {
  PENDING    @map("pending")
  VALIDATING @map("validating")
  READY      @map("ready")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")

  @@map("import_status")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(320)
  name            String    @db.VarChar(120)
  passwordHash    String    @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  memberships             OrganizationMember[]
  sessions                AuthSession[]
  ownedContacts           Contact[]                @relation("ContactOwner")
  ownedCompanies          Company[]                @relation("CompanyOwner")
  ownedDeals              Deal[]                   @relation("DealOwner")
  activities              Activity[]
  ownedTasks              Task[]                   @relation("TaskOwner")
  createdTasks            Task[]                   @relation("TaskCreator")
  uploadedImports         ImportJob[]
  createdTemplates        EmailTemplate[]
  availabilityRules       AvailabilityRule[]
  meetingLinks            MeetingLink[]
  auditLogs               AuditLog[]
  savedViews              SavedView[]
  businessUnitMemberships BusinessUnitMembership[]
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(160)
  slug      String   @unique @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  memberships                OrganizationMember[]
  teams                      Team[]
  invitations                Invitation[]
  sessions                   AuthSession[]
  contacts                   Contact[]
  companies                  Company[]
  deals                      Deal[]
  activities                 Activity[]
  tasks                      Task[]
  pipelines                  Pipeline[]
  stages                     PipelineStage[]
  associations               ObjectAssociation[]
  customProperties           CustomProperty[]
  importJobs                 ImportJob[]
  emailTemplates             EmailTemplate[]
  availabilityRules          AvailabilityRule[]
  meetingLinks               MeetingLink[]
  meetingBookings            MeetingBooking[]
  forms                      Form[]
  formSubmissions            FormSubmission[]
  conversations              Conversation[]
  auditLogs                  AuditLog[]
  savedViews                 SavedView[]
  businessUnits              BusinessUnit[]
  businessUnitMemberships    BusinessUnitMembership[]
  products                   Product[]
  businessUnitProducts       BusinessUnitProduct[]
  priceBookEntries           PriceBookEntry[]
  forecastCategories         ForecastCategory[]
  dealLineItems              DealLineItem[]
  dealParticipants           DealParticipant[]
  salesPerformanceEvents     SalesPerformanceEvent[]
  referrals                  Referral[]
  fieldVisits                FieldVisit[]
  metricDefinitions          MetricDefinition[]
  metricDefinitionVersions   MetricDefinitionVersion[]
  dailyMetricEntries         DailyMetricEntry[]
  metricValidationRules      MetricValidationRule[]
  kpiTargets                 KpiTarget[]
  businessCalendars          BusinessCalendar[]
  businessCalendarExceptions BusinessCalendarException[]
  actionPlans                ActionPlan[]
  legacySourceLinks          LegacySourceLink[]
}

model OrganizationMember {
  id                     String           @id @default(uuid()) @db.Uuid
  organizationId         String           @map("organization_id") @db.Uuid
  userId                 String           @map("user_id") @db.Uuid
  role                   OrganizationRole @default(USER)
  teamId                 String?          @map("team_id") @db.Uuid
  selectedBusinessUnitId String?          @map("selected_business_unit_id") @db.Uuid
  status                 MemberStatus     @default(ACTIVE)
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                 Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  selectedBusinessUnit BusinessUnit? @relation("SelectedBusinessUnit", fields: [selectedBusinessUnitId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, role, status])
  @@index([organizationId, selectedBusinessUnitId])
  @@map("organization_members")
}

model BusinessUnit {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  name           String             @db.VarChar(160)
  slug           String             @db.VarChar(80)
  description    String?
  status         BusinessUnitStatus @default(ACTIVE)
  displayOrder   Int                @default(0) @map("display_order")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships        BusinessUnitMembership[]
  selectedByMembers  OrganizationMember[]     @relation("SelectedBusinessUnit")
  pipelines          Pipeline[]
  deals              Deal[]
  forms              Form[]
  products           BusinessUnitProduct[]
  forecastCategories ForecastCategory[]
  businessCalendars  BusinessCalendar[]

  @@unique([organizationId, slug])
  @@unique([organizationId, name])
  @@index([organizationId, status, displayOrder])
  @@map("business_units")
}

model BusinessUnitMembership {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  businessUnitId String             @map("business_unit_id") @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  workFunction   WorkFunction       @map("work_function")
  isManager      Boolean            @default(false) @map("is_manager")
  status         BusinessUnitStatus @default(ACTIVE)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessUnitId, userId, workFunction])
  @@index([organizationId, userId, status])
  @@index([organizationId, businessUnitId, workFunction, status])
  @@map("business_unit_memberships")
}

model Team {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(120)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String           @db.VarChar(320)
  role           OrganizationRole @default(USER)
  tokenHash      String           @unique @map("token_hash") @db.VarChar(64)
  expiresAt      DateTime         @map("expires_at") @db.Timestamptz(3)
  acceptedAt     DateTime?        @map("accepted_at") @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@index([expiresAt])
  @@map("invitations")
}

model AuthSession {
  id                   String   @id @default(uuid()) @db.Uuid
  tokenHash            String   @unique @map("token_hash") @db.VarChar(64)
  userId               String   @map("user_id") @db.Uuid
  activeOrganizationId String   @map("active_organization_id") @db.Uuid
  expiresAt            DateTime @map("expires_at") @db.Timestamptz(3)
  lastSeenAt           DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization Organization @relation(fields: [activeOrganizationId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([activeOrganizationId])
  @@map("auth_sessions")
}

model Contact {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  firstName      String?   @map("first_name") @db.VarChar(120)
  lastName       String?   @map("last_name") @db.VarChar(120)
  email          String?   @db.VarChar(320)
  phone          String?   @db.VarChar(40)
  mobilePhone    String?   @map("mobile_phone") @db.VarChar(40)
  jobTitle       String?   @map("job_title") @db.VarChar(120)
  lifecycleStage String?   @map("lifecycle_stage") @db.VarChar(80)
  leadStatus     String?   @map("lead_status") @db.VarChar(80)
  source         String?   @db.VarChar(120)
  memo           String?
  customFields   Json      @default("{}") @map("custom_fields") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User?            @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  formSubmissions FormSubmission[]
  meetingBookings MeetingBooking[]
  conversations   Conversation[]

  @@unique([organizationId, email])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, ownerUserId])
  @@map("contacts")
}

model Company {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  ownerUserId    String?   @map("owner_user_id") @db.Uuid
  name           String    @db.VarChar(200)
  domain         String?   @db.VarChar(255)
  phone          String?   @db.VarChar(40)
  industry       String?   @db.VarChar(120)
  address        String?
  city           String?   @db.VarChar(120)
  prefecture     String?   @db.VarChar(120)
  postalCode     String?   @map("postal_code") @db.VarChar(20)
  websiteUrl     String?   @map("website_url")
  employeeCount  Int?      @map("employee_count")
  annualRevenue  Decimal?  @map("annual_revenue") @db.Decimal(18, 2)
  customFields   Json      @default("{}") @map("custom_fields") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?        @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, domain])
  @@index([organizationId, deletedAt, updatedAt])
  @@index([organizationId, ownerUserId])
  @@map("companies")
}

model Pipeline {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  businessUnitId String?  @map("business_unit_id") @db.Uuid
  name           String   @db.VarChar(160)
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnit BusinessUnit?   @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  stages       PipelineStage[]
  deals        Deal[]

  @@unique([organizationId, name])
  @@index([organizationId, businessUnitId, isDefault])
  @@map("pipelines")
}

model PipelineStage {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  pipelineId     String    @map("pipeline_id") @db.Uuid
  name           String    @db.VarChar(120)
  sortOrder      Int       @map("order")
  probability    Int       @default(0)
  stageType      StageType @default(OPEN) @map("stage_type")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@unique([pipelineId, sortOrder])
  @@unique([pipelineId, name])
  @@index([organizationId])
  @@map("pipeline_stages")
}

model Deal {
  id                  String              @id @default(uuid()) @db.Uuid
  organizationId      String              @map("organization_id") @db.Uuid
  businessUnitId      String?             @map("business_unit_id") @db.Uuid
  ownerUserId         String?             @map("owner_user_id") @db.Uuid
  pipelineId          String              @map("pipeline_id") @db.Uuid
  stageId             String              @map("stage_id") @db.Uuid
  forecastCategoryId  String?             @map("forecast_category_id") @db.Uuid
  name                String              @db.VarChar(200)
  amount              Decimal?            @db.Decimal(18, 2)
  expectedCloseDate   DateTime?           @map("expected_close_date") @db.Date
  closeDate           DateTime?           @map("close_date") @db.Date
  probability         Int                 @default(0)
  status              DealStatus          @default(OPEN)
  decisionMakerStatus DecisionMakerStatus @default(UNKNOWN) @map("decision_maker_status")
  qualificationResult QualificationResult @default(UNDETERMINED) @map("qualification_result")
  lostReason          String?             @map("lost_reason")
  source              String?             @db.VarChar(120)
  externalId          String?             @map("external_id") @db.VarChar(160)
  legacyProgress      String?             @map("legacy_progress") @db.VarChar(160)
  wonAt               DateTime?           @map("won_at") @db.Timestamptz(3)
  lostAt              DateTime?           @map("lost_at") @db.Timestamptz(3)
