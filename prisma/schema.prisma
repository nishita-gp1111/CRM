model MetricDefinition {
  id                  String               @id @default(uuid()) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  businessUnitId      String?              @map("business_unit_id") @db.Uuid
  key                 String               @db.VarChar(120)
  displayName         String               @map("display_name") @db.VarChar(160)
  description         String?
  category            MetricCategory       @default(ACTIVITY)
  unit                MetricUnit           @default(COUNT)
  sourceType          MetricSourceType     @map("source_type")
  aggregation         MetricAggregation    @default(SUM)
  workFunction        WorkFunction?        @map("work_function")
  objectType          String?              @map("object_type") @db.VarChar(80)
  dateField           String?              @map("date_field") @db.VarChar(80)
  attributionRole     DealParticipantRole? @map("attribution_role")
  numeratorMetricId   String?              @map("numerator_metric_id") @db.Uuid
  denominatorMetricId String?              @map("denominator_metric_id") @db.Uuid
  isActive            Boolean              @default(true) @map("is_active")
  isPrimary           Boolean              @default(false) @map("is_primary")
  isVisibleByDefault  Boolean              @default(true) @map("is_visible_by_default")
  displayOrder        Int                  @default(0) @map("display_order")
  minSampleSize       Int                  @default(0) @map("min_sample_size")
  queryDefinition     Json                 @default("{}") @map("query_definition") @db.JsonB
  filterDefinition    Json                 @default("{}") @map("filter_definition") @db.JsonB
  metadata            Json                 @default("{}") @db.JsonB
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     MetricDefinitionVersion[]
  dailyEntries DailyMetricEntry[]
  rules        MetricValidationRule[]
  targets      KpiTarget[]
  actionPlans  ActionPlan[]

  @@unique([organizationId, key])
  @@index([organizationId, businessUnitId, workFunction, isActive])
  @@index([organizationId, sourceType, aggregation])
  @@map("metric_definitions")
}

model MetricDefinitionVersion {
  id                 String            @id @default(uuid()) @db.Uuid
  organizationId     String            @map("organization_id") @db.Uuid
  metricDefinitionId String            @map("metric_definition_id") @db.Uuid
